# Groq is River's preferred real-model provider. Keep credentials in .env, never in this file.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_SPEECH_MODEL=canopylabs/orpheus-v1-english
# Gemini is River's preferred speech provider when configured. Groq remains the
# transcription provider and an automatic speech fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_SPEECH_MODEL=gemini-3.1-flash-tts-preview
GEMINI_SPEECH_VOICE=Aoede
# Optional fallback provider. Leave unset for the no-cost hackathon path.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
REALTIME_MODEL=gpt-realtime
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
FIELD_ENCRYPTION_KEY=replace-with-a-separate-long-random-secret
PORT=8787
APP_ORIGIN=http://127.0.0.1:8787
ENFORCE_HTTPS=true
RETENTION_DAYS=365
# Shared PostgreSQL-backed abuse and cost controls. Tune after observing real use.
RATE_LIMIT_IP_PER_MINUTE=180
DAILY_CHAT_LIMIT=120
DAILY_VOICE_TRANSCRIPTION_LIMIT=45
DAILY_VOICE_SPEECH_LIMIT=60
DAILY_VOICE_TURN_LIMIT=45
# Cloudflare Turnstile. Keep REQUIRED=false until both the browser site key and
# server secret are configured in the same deployment.
TURNSTILE_REQUIRED=false
TURNSTILE_SECRET=
VITE_TURNSTILE_SITE_KEY=
# Never expose this in the browser. It protects GET /api/internal/usage.
OWNER_ANALYTICS_KEY=replace-with-a-separate-long-random-secret
# Optional production email delivery through Resend.
RESEND_API_KEY=
EMAIL_FROM="River <security@example.com>"
