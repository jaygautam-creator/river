# Optional: River uses the local reply engine when this is unset.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
REALTIME_MODEL=gpt-realtime
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
PORT=8787
APP_ORIGIN=http://127.0.0.1:8787
RETENTION_DAYS=365
# Optional production email delivery through Resend.
RESEND_API_KEY=
EMAIL_FROM="River <security@example.com>"
# Required in production; encrypts TOTP MFA secrets at rest.
FIELD_ENCRYPTION_KEY=replace-with-a-separate-long-random-secret
